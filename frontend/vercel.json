{
  "headers": [
    {
      "source": "/share",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "Referrer-Policy", "value": "no-referrer" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://personaapp-backend.fly.dev/api/$1"
    },
    {
      "source": "/docs",
      "destination": "https://personaapp-backend.fly.dev/docs"
    },
    {
      "source": "/openapi.json",
      "destination": "https://personaapp-backend.fly.dev/openapi.json"
    },
    {
      "source": "/redoc",
      "destination": "https://personaapp-backend.fly.dev/redoc"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
